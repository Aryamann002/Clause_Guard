// prisma/schema.prisma

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = "file:./dev.db"
}

model User {
  id            String         @id @default(cuid())
  email         String?        @unique
  passwordHash  String?
  createdAt     DateTime       @default(now())
  updatedAt     DateTime       @updatedAt
  documents     Document[]
  consultations Consultation[]
}

model Document {
  id               String        @id @default(cuid())
  userId           String?
  title            String
  originalFilename String
  jurisdiction     String        @default("IN")
  rawText          String
  summaryEn        String?
  summaryHi        String?
  overallRiskScore Float?
  createdAt        DateTime      @default(now())
  updatedAt        DateTime      @updatedAt
  user             User?         @relation(fields: [userId], references: [id])
  clauses          Clause[]
  analysisMeta     AnalysisMeta?
  consultations    Consultation[]
}

model Clause {
  id                 String           @id @default(cuid())
  documentId         String
  index              Int
  heading            String?
  text               String
  category           String
  riskLevel          String           // "LOW", "MEDIUM", "HIGH"
  uncertaintyLevel   String           // "HIGH_CONFIDENCE", "MEDIUM_CONFIDENCE", "LOW_CONFIDENCE"
  riskExplanationEn  String
  riskExplanationHi  String?
  userImpactNotes    String?
  document           Document         @relation(fields: [documentId], references: [id], onDelete: Cascade)
  sources            ClauseSource[]
}

model ClauseSource {
  id         String @id @default(cuid())
  clauseId   String
  title      String
  url        String
  sourceType String // "act", "case_law", "regulation"
  clause     Clause @relation(fields: [clauseId], references: [id], onDelete: Cascade)
}

model AnalysisMeta {
  id              String   @id @default(cuid())
  documentId      String   @unique
  aiModelUsed     String
  totalClauses    Int
  highRiskCount   Int
  mediumRiskCount Int
  lowRiskCount    Int
  analysisTimeMs  Int
  document        Document @relation(fields: [documentId], references: [id], onDelete: Cascade)
}

model Lawyer {
  id                  String         @id @default(cuid())
  name                String
  profileImageUrl     String
  specialties         String         // Comma-separated for SQLite compatibility
  languages           String         // Comma-separated for SQLite compatibility
  yearsExperience     Int
  feePerSession       Int            // INR
  sessionDurationMins Int
  rating              Float
  totalConsults       Int
  isVerified          Boolean        @default(true)
  consultations       Consultation[]
}

model Consultation {
  id                 String             @id @default(cuid())
  userId             String?
  lawyerId           String
  documentId         String?
  scheduledAt        DateTime
  status             String             @default("PENDING") // "PENDING", "CONFIRMED", etc.
  preConsultQuestions String?
  callLink           String?
  createdAt          DateTime           @default(now())
  user               User?              @relation(fields: [userId], references: [id])
  lawyer             Lawyer             @relation(fields: [lawyerId], references: [id])
  document           Document?          @relation(fields: [documentId], references: [id])
  payment            Payment?
}

model Payment {
  id              String        @id @default(cuid())
  consultationId  String        @unique
  amount          Int
  currency        String        @default("INR")
  status          String        // "PENDING", "SUCCESS", "FAILED"
  paymentProvider String        @default("mock")
  createdAt       DateTime      @default(now())
  consultation    Consultation  @relation(fields: [consultationId], references: [id])
}
